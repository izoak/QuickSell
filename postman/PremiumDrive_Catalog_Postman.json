{
    "info": {
      "name": "PremiumDrive Catalog API",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
      {"key": "base_url", "value": "http://localhost:8000", "type": "string"},
      {"key": "access_token", "value": "", "type": "string"},
      {"key": "vehicle_id", "value": "1", "type": "string"},
      {"key": "category_id", "value": "1", "type": "string"}
    ],
    "item": [
      {
        "name": "VEHICLES",
        "item": [
          {
            "name": "GET /vehicles/",
            "request": {"method": "GET", "url": {"raw": "{{base_url}}/api/vehicles/", "host": ["{{base_url}}"], "path": ["api", "vehicles", ""]}}
          },
          {
            "name": "GET /vehicles/?type=car",
            "request": {"method": "GET", "url": {"raw": "{{base_url}}/api/vehicles/?type=car", "host": ["{{base_url}}"], "path": ["api", "vehicles", ""], "query": [{"key": "type", "value": "car"}]}}
          },
          {
            "name": "GET /vehicles/?brand=BMW",
            "request": {"method": "GET", "url": {"raw": "{{base_url}}/api/vehicles/?brand=BMW", "host": ["{{base_url}}"], "path": ["api", "vehicles", ""], "query": [{"key": "brand", "value": "BMW"}]}}
          },
          {
            "name": "GET /vehicles/{id}/",
            "request": {"method": "GET", "url": {"raw": "{{base_url}}/api/vehicles/{{vehicle_id}}/", "host": ["{{base_url}}"], "path": ["api", "vehicles", "{{vehicle_id}}", ""]}}
          },
          {
            "name": "POST /vehicles/ (Admin)",
            "request": {
              "method": "POST",
              "header": [
                {"key": "Content-Type", "value": "application/json"},
                {"key": "Authorization", "value": "Bearer {{access_token}}"}
              ],
              "body": {"mode": "raw", "raw": "{\n  \"name\": \"911 Turbo S\",\n  \"brand\": \"Porsche\",\n  \"price\": 25000000.00,\n  \"type\": \"car\",\n  \"image\": \"https://example.com/porsche-911.jpg\",\n  \"category\": 1,\n  \"year\": 2024,\n  \"description\": \"Самый мощный 911\",\n  \"engine\": \"3.8L Twin-Turbo\",\n  \"horsepower\": 650,\n  \"available\": true\n}"},
              "url": {"raw": "{{base_url}}/api/vehicles/", "host": ["{{base_url}}"], "path": ["api", "vehicles", ""]}
            }
          },
          {
            "name": "PUT /vehicles/{id}/ (Admin) ⭐ НОВЫЙ",
            "request": {
              "method": "PUT",
              "header": [
                {"key": "Content-Type", "value": "application/json"},
                {"key": "Authorization", "value": "Bearer {{access_token}}"}
              ],
              "body": {"mode": "raw", "raw": "{\n  \"name\": \"911 Turbo S Updated\",\n  \"brand\": \"Porsche\",\n  \"price\": 26000000.00,\n  \"type\": \"car\",\n  \"image\": \"https://example.com/porsche-911-updated.jpg\",\n  \"category\": 1,\n  \"year\": 2025,\n  \"description\": \"Обновленная версия\",\n  \"engine\": \"3.8L Twin-Turbo\",\n  \"horsepower\": 650,\n  \"available\": true\n}"},
              "url": {"raw": "{{base_url}}/api/vehicles/{{vehicle_id}}/", "host": ["{{base_url}}"], "path": ["api", "vehicles", "{{vehicle_id}}", ""]}
            }
          },
          {
            "name": "DELETE /vehicles/{id}/ (Admin) ⭐ НОВЫЙ",
            "request": {
              "method": "DELETE",
              "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
              "url": {"raw": "{{base_url}}/api/vehicles/{{vehicle_id}}/", "host": ["{{base_url}}"], "path": ["api", "vehicles", "{{vehicle_id}}", ""]}
            }
          }
        ]
      },
      {
        "name": "CATEGORIES",
        "item": [
          {
            "name": "GET /categories/",
            "request": {"method": "GET", "url": {"raw": "{{base_url}}/api/categories/", "host": ["{{base_url}}"], "path": ["api", "categories", ""]}}
          },
          {
            "name": "POST /categories/ (Admin) ⭐ НОВЫЙ",
            "request": {
              "method": "POST",
              "header": [
                {"key": "Content-Type", "value": "application/json"},
                {"key": "Authorization", "value": "Bearer {{access_token}}"}
              ],
              "body": {"mode": "raw", "raw": "{\n  \"name\": \"Ferrari\"\n}"},
              "url": {"raw": "{{base_url}}/api/categories/", "host": ["{{base_url}}"], "path": ["api", "categories", ""]}
            }
          }
        ]
      }
    ]
  }